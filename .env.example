# =============================================================================
# Yara.cash Twitter Intelligence Bot v2
# =============================================================================
# Copy this file to .env and fill in the values you want to use.
# Blank values are optional unless your selected SEARCH_PROVIDER requires them.
# =============================================================================

# ---------------------------------------------------------------------------
# SEARCH
# ---------------------------------------------------------------------------
# Optional JSON override for the built-in search queries.
# Example:
# SEARCH_QUERIES=[{"query":"chipper cash down","category_hint":"competitor_complaint","description":"Chipper outages","query_type":"Top","cooldown_seconds":3600,"max_pages":1,"enabled":true}]
SEARCH_QUERIES=

MAX_TWEET_AGE_MINUTES=120
MIN_REPLIES_TOP=3
MIN_LIKES_TOP=5
MIN_REPLIES_LATEST=2
MIN_LIKES_LATEST=3
NUM_REPLY_OPTIONS=4
POLL_INTERVAL=900

# Search provider options:
# - twitterapi_io : default production read path
# - xai_x_search  : Grok/X Search model-driven discovery path
# - twscrape      : legacy fallback scraper
# - manual_only   : disables live search; use !smoke / !ingest only
SEARCH_PROVIDER=twitterapi_io

# Optional UTC day window for live search.
# Leave blank to disable.
# 0 = today only, 1 = since yesterday 00:00 UTC, 7 = last 7 days
SEARCH_SINCE_DAYS=

# Low-cost / high-precision controls
MAX_API_REQUESTS_PER_SCAN=4
MAX_LOCAL_CANDIDATES_PER_SCAN=8
MAX_AI_CANDIDATES_PER_SCAN=4
MAX_DISCORD_APPROVALS_PER_SCAN=2
ENABLE_LATEST_FALLBACK=false
LANE_EMPTY_SCAN_THRESHOLD=3

# Optional: when true, the bot posts a sampled "top 3 discarded candidates"
# summary to #bot-status for tuning.
DEBUG_DISCARDED_TO_STATUS=false

# Optional: when set with SEARCH_PROVIDER=twitterapi_io, the bot checks direct
# mentions for this username each scan and skips keyword brand queries by default.
BRAND_X_USERNAME=

# ---------------------------------------------------------------------------
# GEMINI
# ---------------------------------------------------------------------------
# Required for live classification/reply generation unless SEARCH_PROVIDER is
# manual_only or xai_x_search.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Optional: override the default brand prompt/context used for Gemini.
# Keep this as a single line if you set it in .env.
BRAND_CONTEXT=

# ---------------------------------------------------------------------------
# XAI / GROK X SEARCH
# ---------------------------------------------------------------------------
# Required only when SEARCH_PROVIDER=xai_x_search
XAI_API_KEY=
XAI_MODEL=grok-4-1-fast-reasoning
XAI_MAX_TURNS=2
XAI_REQUEST_TIMEOUT_SECONDS=30
# Optional comma-separated author filters (max 10 handles). Set only one.
XAI_ALLOWED_X_HANDLES=
XAI_EXCLUDED_X_HANDLES=
XAI_ENABLE_IMAGE_UNDERSTANDING=false
XAI_ENABLE_VIDEO_UNDERSTANDING=false
XAI_DEBUG_LOG_TOOL_CALLS=false

# ---------------------------------------------------------------------------
# DISCORD BOT
# ---------------------------------------------------------------------------
# Required
DISCORD_BOT_TOKEN=

# Optional but recommended. If set, the bot can auto-create missing channels.
DISCORD_GUILD_ID=

# Optional: set these if you want to use existing channels instead of auto-created ones.
DISCORD_CH_COMPETITOR=
DISCORD_CH_SEEKERS=
DISCORD_CH_BRAND=
DISCORD_CH_APPROVED=
DISCORD_CH_REJECTED=
DISCORD_CH_STATUS=

# Discord command authorization
# - enforce: block unauthorized commands/interactions (recommended)
# - audit: log unauthorized attempts but allow execution
DISCORD_COMMAND_AUTH_MODE=enforce
# Comma-separated numeric IDs. In enforce mode, configure:
# (user OR role) AND channel allowlists.
DISCORD_ALLOWED_USER_IDS=
DISCORD_ALLOWED_ROLE_IDS=
DISCORD_ALLOWED_CHANNEL_IDS=
# If true, button actions and custom replies must come from the original
# review channel/message context.
DISCORD_REQUIRE_PENDING_CHANNEL_MATCH=true

# ---------------------------------------------------------------------------
# TELEGRAM (optional fallback alerts)
# ---------------------------------------------------------------------------
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---------------------------------------------------------------------------
# X / TWITTER POSTING (used for approved replies)
# ---------------------------------------------------------------------------
# These are needed if you want the bot to post replies back to X.
# Manual and smoke items always dry-run even if these are blank.
X_AUTH_TOKEN=
X_CSRF_TOKEN=
X_COOKIE=
X_POSTING_DRY_RUN=false

# ---------------------------------------------------------------------------
# TWITTERAPI.IO SEARCH (default live search provider)
# ---------------------------------------------------------------------------
# Required only when SEARCH_PROVIDER=twitterapi_io
TWITTERAPI_IO_API_KEY=

# ---------------------------------------------------------------------------
# TWSCRAPE (legacy fallback search provider)
# ---------------------------------------------------------------------------
# Required only when SEARCH_PROVIDER=twscrape
TWSCRAPE_USERNAME=
TWSCRAPE_PASSWORD=
TWSCRAPE_EMAIL=
TWSCRAPE_EMAIL_PASSWORD=

# Optional fallback when password login hits Cloudflare:
# paste the full cookie string from a logged-in burner X account
# (it must include at least auth_token and ct0).
TWSCRAPE_COOKIES=

# Optional overrides
TWSCRAPE_DB_PATH=accounts.db
TWSCRAPE_AUTO_RESET_LOCKS=true
TWSCRAPE_LOCK_RESET_COOLDOWN=300

# ---------------------------------------------------------------------------
# DATABASE
# ---------------------------------------------------------------------------
DB_PATH=bot_state.db
